# User/group IDs that own the Lidarr config volume.
# `id -u` and `id -g` on the host running docker.
PUID=1000
PGID=1000

# Timezone for log timestamps. e.g. America/New_York, Europe/London.
TZ=Etc/UTC

# Set true only if Aurral sits behind a reverse proxy that sets X-Forwarded-*.
TRUST_PROXY=false

# Host-side ports. Defaults match Aurral / Lidarr conventions.
# Override (e.g. AURRAL_PORT=3101, LIDARR_PORT=8786) if those ports are
# already taken on this host by your real stack.
AURRAL_PORT=3001
LIDARR_PORT=8686
